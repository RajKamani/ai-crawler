# Supabase Database Settings (Required)
# Retrieve these from your Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-jwt-key

# Groq API Configuration (Required for AI Summaries)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# Reddit API Configuration (Optional)
# If left empty, the crawler automatically falls back to public JSON feeds
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-content-crawler:v1.0.0

# GitHub API Configuration (Optional)
# If left empty, GitHub Search runs without authentication (rate limited to 60 req/hr)
GITHUB_TOKEN=
